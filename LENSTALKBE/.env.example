# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/lenstalkdb

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin Seed (used during first-time seeding)
ADMIN_EMAIL=admin@lenstalkmedia.com
ADMIN_PASSWORD=Admin@123

# CORS - Frontend URL
CLIENT_URL=http://localhost:3000
